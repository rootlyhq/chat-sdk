<div id="message-<%= message.id %>" class="flex <%= from_bot ? '' : 'justify-end' %>">
  <div class="max-w-[80%] px-4 py-2 rounded-2xl text-sm <%= from_bot ? 'bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100' : 'bg-red-600 text-white' %>">
    <% if from_bot %>
      <span class="text-xs font-medium text-gray-500 dark:text-gray-400 block mb-1">Bot</span>
    <% end %>
    <p><%= message.respond_to?(:text) ? message.text : message %></p>
  </div>
</div>
