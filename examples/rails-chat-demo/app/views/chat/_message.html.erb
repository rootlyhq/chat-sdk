<div id="message-<%= message.id %>" class="flex <%= from_bot ? '' : 'justify-end' %>">
  <div class="max-w-[80%]">
    <% if from_bot %>
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-950 flex items-center justify-center shrink-0 mt-0.5">
          <span class="text-sm">🤖</span>
        </div>
        <div>
          <span class="text-[11px] font-medium text-gray-400 block mb-1">Bot · just now</span>
          <div class="px-4 py-3 rounded-2xl rounded-tl-md bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm border border-gray-100 dark:border-gray-700 text-sm leading-relaxed">
            <p class="whitespace-pre-wrap"><%= message.respond_to?(:text) ? message.text : message %></p>
          </div>
        </div>
      </div>
    <% else %>
      <div class="flex items-start gap-3 justify-end">
        <div>
          <span class="text-[11px] font-medium text-gray-400 block mb-1 text-right">You · just now</span>
          <div class="px-4 py-3 rounded-2xl rounded-tr-md bg-red-600 text-white shadow-sm text-sm leading-relaxed">
            <p class="whitespace-pre-wrap"><%= message.respond_to?(:text) ? message.text : message %></p>
          </div>
        </div>
        <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center shrink-0 mt-0.5">
          <span class="text-sm">👤</span>
        </div>
      </div>
    <% end %>
  </div>
</div>
