<div id="message-<%= message.id %>" class="flex <%= from_bot ? '' : 'justify-end' %>">
  <div class="max-w-[80%] px-4 py-2.5 rounded-2xl text-sm leading-relaxed
    <%= from_bot ? 'bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm' : 'bg-red-600 text-white' %>">
    <% if from_bot %>
      <span class="text-xs font-medium text-gray-400 block mb-1">🤖 Bot</span>
    <% end %>
    <p class="whitespace-pre-wrap"><%= message.respond_to?(:text) ? message.text : message %></p>
  </div>
</div>
