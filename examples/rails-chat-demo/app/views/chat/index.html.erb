<div id="chat-container"
     class="flex flex-col h-[600px] max-w-2xl mx-auto border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden bg-white dark:bg-gray-950"
     data-controller="chat"
     data-chat-channel-value="<%= @channel_id %>">

  <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-800 flex items-center gap-2">
    <span class="text-lg">&#x1F48E;</span>
    <h2 class="font-semibold text-gray-900 dark:text-gray-100">ChatSDK</h2>
    <span class="text-xs text-gray-400">Beta</span>
  </div>

  <div id="messages"
       class="flex-1 overflow-y-auto p-4 space-y-3"
       data-chat-target="messages">
  </div>

  <form class="p-4 border-t border-gray-200 dark:border-gray-800 flex gap-2"
        data-action="submit->chat#send">
    <input type="text"
           data-chat-target="input"
           placeholder="Type a message..."
           class="flex-1 px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 text-sm focus:outline-none focus:border-red-500/50"
           autocomplete="off" />
    <button type="submit"
            class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 transition-colors">
      Send
    </button>
  </form>
</div>
